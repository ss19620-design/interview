{
  "name": "interviewbot",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "preview": "opennextjs-cloudflare && wrangler dev",
    "deploy": "opennextjs-cloudflare && wrangler deploy",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv",
    "db:generate": "prisma generate",
    "db:migrate:local": "wrangler d1 execute interviewbot-db --local --file",
    "db:migrate:remote": "wrangler d1 execute interviewbot-db --remote --file",
    "lint": "eslint"
  },
  "dependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@google/generative-ai": "^0.24.1",
    "@opennextjs/cloudflare": "^1.19.4",
    "@prisma/adapter-d1": "^7.8.0",
    "@prisma/client": "^6.19.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "geist": "^1.7.0",
    "lucide-react": "^1.11.0",
    "next": "^15.5.15",
    "prisma": "^6.19.3",
    "radix-ui": "^1.4.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "shadcn": "^4.5.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.5.15",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
